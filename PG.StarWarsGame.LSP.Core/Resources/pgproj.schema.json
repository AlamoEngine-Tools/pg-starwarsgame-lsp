{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PG StarWarsGame Mod Project",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "description": "Project display name and identity. When omitted, the server falls back to the .pgproj file name (without extension).",
      "type": "string",
      "minLength": 1
    },
    "modinfo": {
      "description": "Optional embedded modinfo metadata. Parsed against the full modinfo spec; the properties listed here are authoring hints only and are not exhaustive.",
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "code"
            ],
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string",
                "minLength": 2,
                "maxLength": 5
              },
              "support": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "custom": {
          "type": "object"
        }
      }
    },
    "directories": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "xml": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "art": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "audio": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ai": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Reserved - currently excluded from XML parsing."
        },
        "storyDialog": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Directories holding story-dialog .txt scripts (chaptered text/media playlists referenced from story events via Story_Dialog). Only files under these directories get the story-dialog language service."
        }
      }
    },
    "localisation": {
      "description": "The project's single localisation source: which directory (relative to this .pgproj) holds the translation files, and what format they're stored in.",
      "type": "object",
      "required": [
        "type",
        "directory"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CSV",
            "DAT",
            "XML",
            "NLS"
          ]
        },
        "directory": {
          "type": "string"
        }
      }
    },
    "projectReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}
