{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PG StarWarsGame Mod Project",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "description": "Project display name and identity. When omitted, the server falls back to the .pgproj file name (without extension).",
      "type": "string",
      "minLength": 1
    },
    "modinfo": {
      "description": "Optional embedded modinfo metadata. Parsed against the full modinfo spec; the properties listed here are authoring hints only and are not exhaustive.",
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "code"
            ],
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string",
                "minLength": 2,
                "maxLength": 5
              },
              "support": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "custom": {
          "type": "object"
        }
      }
    },
    "directories": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "xml": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "art": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "audio": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "text": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ai": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Reserved — currently excluded from XML parsing."
        },
        "textResourceType": {
          "type": "string",
          "description": "Localisation resource type for the text directories (Csv, Xml, Nls, or Dat). Selects how the localisation loader reads translation files for this project."
        }
      }
    },
    "projectReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}
